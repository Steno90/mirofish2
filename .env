# ============================================================
# MIROFISH — CONFIGURAZIONE TRIPLE-FREE API
# Generato per il fork amadad/mirofish
# ============================================================
# 
# CAPACITA' GIORNALIERA TOTALE GRATUITA:
#   Google Gemini Flash-Lite : 1.000 req/giorno  (orchestrazione)
#   Cerebras llama3.1-8b    : 1.000.000 token/giorno (agenti Twitter)
#   Groq llama-3.1-8b-inst  : 14.400 req/giorno  (agenti Reddit)
#
# = abbondantemente sufficiente per 100+ rounds ogni giorno
# ============================================================
 
 
# --- MOTORE PRINCIPALE ---
# Google Gemini 2.5 Flash-Lite: il modello free con piu' richieste/giorno (1000)
# Usato per: graph building, persona generation, report finale
# NON usato per la simulazione bulk (quella va su Cerebras+Groq)
 
LLM_PROVIDER=openai
LLM_API_KEY=AIzaSyBkBEp0YVWP_6ngmL5nPUnuRRYRsJFeZcY
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.5-flash-lite-preview-06-17
 
 
# --- BOOST SIMULAZIONE (piattaforma Twitter/Info Plaza) ---
# Cerebras llama3.1-8b: 2235 token/secondo, ultraveloce
# 1 milione di token al giorno GRATIS — il motore ideale per agenti bulk
 
LLM_BOOST_API_KEY=csk-94353r3nwtcrpwt5yvkrkh555r9yfcvtf3ktpynx8knxp6yf
LLM_BOOST_BASE_URL=https://api.cerebras.ai/v1
LLM_BOOST_MODEL_NAME=llama3.1-8b
 
 
# --- BOOST 2 SIMULAZIONE (piattaforma Reddit) ---
# Groq llama-3.1-8b-instant: 14.400 req/giorno GRATIS
# Secondo motore parallelo per la simulazione dual-platform
 
LLM_BOOST2_API_KEY=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
LLM_BOOST2_BASE_URL=https://api.groq.com/openai/v1
LLM_BOOST2_MODEL_NAME=llama-3.1-8b-instant
 
 
# --- DATABASE GRAFICO LOCALE ---
# KuzuDB: nessun account, nessun limite, zero configurazione
# Sostituisce completamente Zep Cloud (niente piu' problemi di memory)
 
GRAPH_BACKEND=kuzu
 
 
# --- IMPOSTAZIONI SIMULAZIONE ---
# Delay 4 secondi tra round: sicuro per non colpire mai i rate limit
# Con 100 rounds = 400 secondi extra (~7 min) — assolutamente ok
 
SIMULATION_DELAY=4
 
# Numero agenti: 30 e' un buon valore iniziale
# (puoi aumentare a 50 dopo aver verificato che funziona)
 
MAX_AGENTS=30
 
 
# ============================================================
# NOTE IMPORTANTI:
#
# 1. Questo file si chiama ".env" (con il punto davanti)
#    Deve stare nella ROOT del repo mirofish (non in sottocartelle)
#
# 2. Se il fork non support
